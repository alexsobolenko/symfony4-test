{% extends 'base.html.twig' %}

{% block title %}
  {{ title }}
{% endblock %}

{% block body %}
  <h1 class="my-3">Books</h1>
  <a href="/create/book" class="btn btn-primary my-3">Add new book</a><br>
  <table class="table table-bordered table-stripped text-center my-3">
    <thead class="thead-dark">
      <tr>
        <th style="width: 35%;">Name</th>
        <th style="width: 35%;">Author</th>
        <th style="width: 15%;">Price</th>
        <th style="width: 15%;"></th>
      </tr>
    </thead>
    <tbody>
      {% for book in books %}
        <tr>
          <td>{{ book.name }}</td>
          <td>{{ book.author.name }}</td>
          <td>${{ book.price }}</td>
          <td>
            <a href="{{ path('page_book_edit', {'id': book.id}) }}" class="btn btn-success">Edit</a>
            <a href="{{ path('page_book_delete', {'id': book.id}) }}" class="btn btn-danger">Delete</a>
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
{% endblock %}