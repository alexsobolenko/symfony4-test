{% block form_row %}
    {% spaceless %}
        <div class="field is-horizontal">
            <div class="field-label is-normal">
                {{ form_label(form, null, { "label_attr": { "class": "label-featured" }}) }}
            </div>
            <div class="field-body">
                <div class="field">
                    {{ form_widget(form) }}
                </div>
            </div>
        </div>
    {% endspaceless %}
{% endblock form_row %}

{%- block form_widget_simple -%}
    {%- set type = type|default('text') -%}
    <p class="control is-expanded">
        <input
            type="{{ type }}"
            {{ block('widget_attributes') }}
            {% if value is not empty %}value="{{ value }}" {% endif %}
            class="input"
        />
    </p>
{%- endblock form_widget_simple -%}

{%- block form_widget_compound -%}
    <div {{ block('widget_container_attributes') }}>
        {{- block('form_rows') -}}
        {{- form_rest(form) -}}
    </div>
{%- endblock form_widget_compound -%}

{%- block button_attributes -%}
    id="{{ id }}"
    name="{{ full_name }}"
    {% if disabled %} disabled="disabled"{% endif -%}
    class="button is-primary"
    {{ block('attributes') }}
{%- endblock button_attributes -%}

{%- block button_widget -%}
    {%- if label is empty -%}
        {%- if label_format is not empty -%}
            {% set label = label_format|replace({
                '%name%': name,
                '%id%': id,
            }) %}
        {%- else -%}
            {% set label = name|humanize %}
        {%- endif -%}
    {%- endif -%}
    <div class="field is-horizontal">
        <div class="field-label is-normal"></div>
        <div class="field-body">
            <button
                type="{{ type|default('button') }}"
                {{ block('button_attributes') }}
            >
                {{ translation_domain is same as(false) ? label : label|trans({}, translation_domain) }}
            </button>
        </div>
    </div>
{%- endblock button_widget -%}

{%- block choice_widget_collapsed -%}
    {%- if required and placeholder is none and not placeholder_in_choices and not multiple and (attr.size is not defined or attr.size <= 1) -%}
        {% set required = false %}
    {%- endif -%}
    <div class="select is-fullwidth">
        <select
            {{ block('widget_attributes') }}
            {% if multiple %} multiple="multiple"{% endif %}
        >
            {%- if placeholder is not none -%}
                <option
                    value=""
                    {% if required and value is empty %} selected="selected"{% endif %}
                >
                    {{ placeholder != '' ? (translation_domain is same as(false) ? placeholder : placeholder|trans({}, translation_domain)) }}
                </option>
            {%- endif -%}
            {%- if preferred_choices|length > 0 -%}
                {% set options = preferred_choices %}
                {{- block('choice_widget_options') -}}
                {%- if choices|length > 0 and separator is not none -%}
                    <option disabled="disabled">{{ separator }}</option>
                {%- endif -%}
            {%- endif -%}
            {%- set options = choices -%}
            {{- block('choice_widget_options') -}}
        </select>
    </div>
{%- endblock choice_widget_collapsed -%}
